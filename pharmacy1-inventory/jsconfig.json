{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": ["resources/js/*"],
            "ziggy-js": ["./vendor/tightenco/ziggy"]
        },
        "jsx": "react-jsx",
        "checkJs": false,
        "moduleResolution": "bundler",
        "module": "esnext",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "exclude": ["node_modules", "public"]
}
